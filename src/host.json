{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "extensions": {
    "serviceBus": {
      "prefetchCount": 100,
      "autoCompleteMessages": true,
      "maxConcurrentCalls": 32,
      "maxAutoRenewDuration": "00:05:00",
      "maxMessageBatchSize": 1000
    }
  }
}
